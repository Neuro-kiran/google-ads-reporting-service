# Google Ads API Configuration
# Get these from Google Ads API Console: https://developers.google.com/google-ads/api

# Developer token (required)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# OAuth 2.0 Client Credentials
GOOGLE_ADS_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here

# OAuth 2.0 Refresh Token
# Generate using the OAuth 2.0 flow or use existing token
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# Optional: Login Customer ID for manager account
# Use this if you're accessing managed accounts
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# FastAPI Configuration
FASTAPI_ENV=development
FASTAPI_DEBUG=True

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# RAG Configuration (Optional)
OPENAI_API_KEY=your_openai_key_here
FAISS_INDEX_PATH=./data/campaign_index

# Database (Optional - for caching)
DATABASE_URL=sqlite:///./data/ads_service.db
